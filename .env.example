# Meeting Service — example configuration.
# Copy to `.env` and adjust. All values are optional; the defaults below target a
# docker-compose network. There are NO secrets in this file — fill in your own.

# --- Speech-to-text (Parakeet, OpenAI-compatible /v1/audio/transcriptions) ---
PARAKEET_URL=http://parakeet-asr:5092
PARAKEET_MODEL=istupakov/parakeet-tdt-0.6b-v3-onnx

# --- Speaker diarization (pyannote.audio, /diarize endpoint) ---
DIARIZER_URL=http://pyannote-diarizer:8000

# --- Ollama (LLM + embeddings) ---
# From a container, reach a native host Ollama via host.docker.internal:
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:14b
EMBEDDING_MODEL=qwen3-embedding:0.6b

# --- Qdrant (vector DB for semantic search / linking) ---
QDRANT_URL=http://qdrant:6333

# --- Optional: route chat through an OpenWebUI instance instead of Ollama directly ---
OPENWEBUI_URL=
OPENWEBUI_API_KEY=

# --- Data directories (mount these as volumes) ---
MEETINGS_DIR=/data/meetings
NOTES_DIR=/data/notes

# --- Limits / CORS ---
MAX_UPLOAD_SIZE=524288000
ALLOWED_FRAME_ORIGINS=*
ALLOWED_CORS_ORIGINS=*
